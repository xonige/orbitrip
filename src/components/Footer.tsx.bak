import React, { useState, useEffect } from 'react';
import { Language, SystemSettings } from '../types';

interface FooterProps {
  language: Language;
  settings: SystemSettings | null;
  onNavigate: (view: string, path: string) => void;
}

const Footer: React.FC<FooterProps> = ({ language, settings, onNavigate }) => {
  const isEn = language === Language.EN;
  const year = new Date().getFullYear();
  const time = new Date().toLocaleTimeString();

  const [loadTime, setLoadTime] = useState<number | null>(null);

  useEffect(() => {
    const measure = () => {
        setTimeout(() => {
            try {
                const navEntry = window.performance.getEntriesByType('navigation')[0] as PerformanceNavigationTiming;
                if (navEntry && navEntry.loadEventEnd > 0) {
                    setLoadTime(Math.round(navEntry.loadEventEnd));
                } else {
                    const timing = window.performance.timing;
                    if (timing.loadEventEnd > 0) {
                        setLoadTime(timing.loadEventEnd - timing.navigationStart);
                    }
                }
            } catch (e) {
                // Ignore performance API errors on old browsers
            }
        }, 0);
    };

    if (document.readyState === 'complete') {
        measure();
    } else {
        window.addEventListener('load', measure);
        return () => window.removeEventListener('load', measure);
    }
  }, []);

  const phone = settings?.adminPhoneNumber || '995593456876';
  const email = 'support@orbitrip.ge';

  const fbLink = settings?.socialFacebook || 'https://facebook.com/orbitrip.ge';
  const igLink = settings?.socialInstagram || 'https://instagram.com/orbitrip.ge';

  return (
    <footer className="bg-[#0f172a] text-slate-400 font-sans pt-10 md:pt-16 pb-8 border-t border-slate-800">
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-12 md:mb-16">

          <div className="space-y-6">
            {/* SYNCED LOGO WITH HEADER */}
            <div className="flex items-center cursor-pointer group select-none" onClick={() => onNavigate('HOME', '/')}>
              <div className="flex items-center gap-2.5">
                <div className="relative w-10 h-10">
                  <div className="absolute inset-0 rounded-xl rotate-6 bg-[var(--primary)] transition-all duration-300 group-hover:rotate-12"></div>
                  <div className="absolute inset-0 flex items-center justify-center">
                    <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" strokeWidth="2.5" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="3" />
                      <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10" strokeLinecap="round" />
                      <path d="M22 12c0-5.5-4.5-10-10-10" strokeLinecap="round" strokeDasharray="4 4" />
                    </svg>
                  </div>
                </div>
                <div className="flex flex-col">
                  <span className="text-xl font-black tracking-tight leading-none text-white">
                    ORBI<span className="text-[var(--primary-light)]">TRIP</span>
                  </span>
                  <span className="text-[8px] font-bold uppercase tracking-[0.3em] leading-none mt-0.5 text-gray-500">
                    Georgia
                  </span>
                </div>
              </div>
            </div>

            <p className="text-sm leading-relaxed max-w-xs text-slate-500">
              {isEn
                ? "Your trusted platform for private transfers and tours in Georgia. Verified drivers, fixed prices, and unforgettable experiences."
                : "Ваша надежная платформа для частных трансферов и туров по Грузии. Проверенные водители, фиксированные цены и незабываемые впечатления."}
            </p>

            <div className="flex gap-4">
              <a href={fbLink} target="_blank" rel="noopener noreferrer" className="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-white hover:bg-[#1877F2] transition-colors border border-slate-700 shadow-lg">
                <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
              </a>
              <a href={igLink} target="_blank" rel="noopener noreferrer" className="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-white hover:bg-[#E1306C] transition-colors border border-slate-700 shadow-lg">
                <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" /></svg>
              </a>
            </div>
          </div>

          <div>
            <h3 className="text-white font-bold text-lg mb-6">{isEn ? "Explore" : "Навигация"}</h3>
            <ul className="space-y-4 text-sm">
              <li><button onClick={() => onNavigate('HOME', '/')} className="hover:text-white transition-colors">{isEn ? "Transfers" : "Трансферы"}</button></li>
              <li><button onClick={() => onNavigate('BLOG', '/blog')} className="hover:text-white transition-colors">{isEn ? "Blog & Guides" : "Блог и Гиды"}</button></li>
              <li>
                <button
                  onClick={() => onNavigate('DRIVER_REGISTRATION', '/drive-with-us')}
                  className="flex items-center text-blue-400 hover:text-blue-300 font-bold transition-colors mt-2"
                >
                  <span className="mr-2 text-lg">🚖</span>
                  {isEn ? "Become a Driver" : "Стать Водителем"}
                </button>
              </li>
            </ul>
          </div>

          <div>
            <h3 className="text-white font-bold text-lg mb-6">{isEn ? "Legal" : "Информация"}</h3>
            <ul className="space-y-4 text-sm">
              <li><button onClick={() => onNavigate('LEGAL_TERMS', '/terms')} className="hover:text-white transition-colors">{isEn ? "Terms" : "Условия"}</button></li>
              <li><button onClick={() => onNavigate('LEGAL_PRIVACY', '/privacy')} className="hover:text-white transition-colors">{isEn ? "Privacy" : "Приватность"}</button></li>
            </ul>
          </div>

          <div>
            <h3 className="text-white font-bold text-lg mb-6">{isEn ? "Contact Us" : "Контакты"}</h3>
            <ul className="space-y-4 text-sm">
              <li className="flex items-start gap-3">
                <span className="text-indigo-500 mt-0.5">📞</span>
                <div>
                  <div className="flex flex-wrap gap-2 mb-2">
                    <span className="bg-green-500/20 text-green-400 text-[10px] font-bold px-2 py-0.5 rounded border border-green-500/30">WhatsApp</span>
                    <span className="bg-purple-500/20 text-purple-400 text-[10px] font-bold px-2 py-0.5 rounded border border-purple-500/30">Viber</span>
                    <span className="bg-blue-500/20 text-blue-400 text-[10px] font-bold px-2 py-0.5 rounded border border-blue-500/30">Telegram</span>
                  </div>
                  <a href={`tel:${phone}`} className="text-white font-mono hover:text-indigo-400 transition-colors text-lg">+{phone}</a>
                </div>
              </li>
              <li className="flex items-start gap-3">
                <span className="text-indigo-50 mt-0.5">✉️</span>
                <div><a href={`mailto:${email}`} className="text-white font-mono hover:text-indigo-400 transition-colors">{email}</a></div>
              </li>
            </ul>
          </div>

        </div>

        <div className="pt-8 border-t border-slate-800 flex flex-col items-center justify-center gap-4 text-xs text-center">
          <p>© {year} OrbiTrip Georgia. {isEn ? "All rights reserved." : "Все права защищены."}</p>
          <div className="flex flex-wrap gap-4 items-center justify-center">
            <span className="text-slate-600 font-mono italic">Build: {new Date().toLocaleTimeString()}</span>
            <span className="bg-slate-800 text-slate-400 px-3 py-1 rounded-full font-mono text-[10px] border border-slate-700 uppercase tracking-widest">Platform: orbitrip.ge</span>
            {loadTime !== null && loadTime > 0 && (
                <span className="text-[10px] font-mono font-bold text-emerald-400 border border-emerald-500/30 px-3 py-1 rounded-full bg-emerald-900/30 flex items-center gap-1.5 shadow-sm">
                    <span className="animate-pulse">⚡</span> {isEn ? "Load Time:" : "Загрузка:"} {(loadTime / 1000).toFixed(2)}s
                </span>
            )}
            <div className="relative group cursor-help">
              <span className="text-blue-400 font-bold bg-blue-900/30 px-3 py-1 rounded-full border border-blue-500/50 animate-pulse uppercase tracking-widest text-[9px] transition-all group-hover:bg-blue-500 group-hover:text-white">
                v14.4 (PRO)
              </span>
              
              {/* VERSION HISTORY TOOLTIP */}
              <div className="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-64 p-4 bg-slate-900 border border-slate-700 rounded-2xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 pointer-events-none">
                <div className="text-[10px] font-black text-white mb-3 uppercase tracking-widest border-b border-slate-800 pb-2">Version History</div>
                <div className="space-y-3">
                  <div className="flex flex-col gap-0.5">
                    <span className="text-blue-400 font-black text-[9px] uppercase tracking-tighter">v14.4 (LATEST)</span>
                    <span className="text-[10px] text-slate-400 leading-tight">UI Enrichment: SVG Icons, Google Reviews branding, Blog expansion.</span>
                  </div>
                  <div className="flex flex-col gap-0.5">
                    <span className="text-slate-200 font-black text-[9px] uppercase tracking-tighter">v14.2</span>
                    <span className="text-[10px] text-slate-500 leading-tight">Legal pages, Mtskheta BG optimization, full Georgian removal.</span>
                  </div>
                  <div className="flex flex-col gap-0.5">
                    <span className="text-slate-200 font-black text-[9px] uppercase tracking-tighter">v14.0</span>
                    <span className="text-[10px] text-slate-500 leading-tight">Full Rebuild: Glassmorphism UI, EN/RU focus.</span>
                  </div>
                  <div className="flex flex-col gap-0.5">
                    <span className="text-slate-200 font-black text-[9px] uppercase tracking-tighter">v13.0</span>
                    <span className="text-[10px] text-slate-500 leading-tight">Production Server Deployment & Database initialization.</span>
                  </div>
                </div>
                {/* Tooltip Arrow */}
                <div className="absolute top-full left-1/2 -translate-x-1/2 -mt-1.5 border-[6px] border-transparent border-t-slate-700"></div>
              </div>
            </div>

            {/* SECURITY BADGE */}
            <div className="flex items-center gap-2 text-slate-500 bg-slate-900/50 px-3 py-1 rounded-full border border-slate-800 shadow-sm cursor-help hover:text-slate-300 transition-colors group relative" title="Cloudflare Protected">
              <svg className="w-3 h-3 text-[#F38020]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" /></svg>
              <span className="text-[10px] font-medium tracking-wide">
                {isEn ? "Secured by Cloudflare" : "Защита Cloudflare"}
              </span>
              <span className="text-slate-700">•</span>
              <span className="text-[10px] font-medium tracking-wide flex items-center">
                <span className="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5 animate-pulse"></span>
                {isEn ? "SSL Encrypted" : "SSL Шифрование"}
              </span>
            </div>
          </div>
        </div>

      </div>
    </footer>
  );
};

export default Footer;