                          <Navigation size={32} />
                      </div>
                      <h3 className="text-xl font-black text-slate-900 uppercase italic leading-none">{isEn ? "Total Route Freedom" : "–°–≤–ĺ–Ī–ĺ–ī–į –ľ–į—Ä—ą—Ä—É—ā–į"}</h3>
                      <p className="text-sm font-bold text-slate-400 leading-relaxed uppercase tracking-tight opacity-70">
                          {isEn ? "Stop anywhere for photos, coffee, or sightseeing at no extra cost." : "–ě—Ā—ā–į–Ĺ–į–≤–Ľ–ł–≤–į–Ļ—ā–Ķ—Ā—Ć —É –Ľ—é–Ī—č—Ö –ī–ĺ—Ā—ā–ĺ–Ņ—Ä–ł–ľ–Ķ—á–į—ā–Ķ–Ľ—Ć–Ĺ–ĺ—Ā—ā–Ķ–Ļ –ł–Ľ–ł –Ĺ–į –ļ–ĺ—Ą–Ķ –Ī–Ķ—Ā–Ņ–Ľ–į—ā–Ĺ–ĺ."}
                      </p>
                             <div className="grid grid-cols-1 md:grid-cols-3 gap-0 md:gap-8">
                  {[
                    { name: Sarah M., location: "London, UK", text: isEn ? "Incredible service! Driver was punctual and the car was spotless. Made our trip to Kazbegi unforgettable." : "–Ě–Ķ–≤–Ķ—Ä–ĺ—Ź—ā–Ĺ—č–Ļ —Ā–Ķ—Ä–≤–ł—Ā! –í–ĺ–ī–ł—ā–Ķ–Ľ—Ć –Ī—č–Ľ –Ņ—É–Ĺ–ļ—ā—É–į–Ľ–Ķ–Ĺ. –ü–ĺ–Ķ–∑–ī–ļ–į –≤ –ö–į–∑–Ī–Ķ–≥–ł –Ī—č–Ľ–į –Ĺ–Ķ–∑–į–Ī—č–≤–į–Ķ–ľ–ĺ–Ļ." },
                    { name: Marco R., location: "Rome, Italy", text: isEn ? "Best transfer service in Georgia. Fixed prices, no surprises. Highly recommended!" : "–õ—É—á—ą–ł–Ļ —ā—Ä–į–Ĺ—Ā—Ą–Ķ—Ä –≤ –ď—Ä—É–∑–ł–ł. –§–ł–ļ—Ā–ł—Ä–ĺ–≤–į–Ĺ–Ĺ—č–Ķ —Ü–Ķ–Ĺ—č, –Ī–Ķ–∑ —Ā—é—Ä–Ņ—Ä–ł–∑–ĺ–≤. –†–Ķ–ļ–ĺ–ľ–Ķ–Ĺ–ī—É—é!" },
                    { name: Elena K., location: "Berlin, DE", text: isEn ? "Clean car, friendly driver, fair price. This is exactly what we needed for our family trip." : "–ß–ł—Ā—ā–į—Ź –ľ–į—ą–ł–Ĺ–į, –≤–Ķ–∂–Ľ–ł–≤—č–Ļ –≤–ĺ–ī–ł—ā–Ķ–Ľ—Ć, —á–Ķ—Ā—ā–Ĺ–į—Ź —Ü–Ķ–Ĺ–į. –Ę–ĺ —á—ā–ĺ –Ĺ—É–∂–Ĺ–ĺ –ī–Ľ—Ź —Ā–Ķ–ľ—Ć–ł." }
                  ].map((review, i) => (
                      <div key={i} className="bg-white p-6 md:p-10 rounded-none md:rounded-[40px] shadow-sm border-y md:border border-slate-100 flex flex-col h-full group hover:shadow-xl transition-all duration-700 text-center items-center md:text-left md:items-start">
                          <p className="text-lg text-slate-900 leading-relaxed mb-12 flex-grow font-black tracking-tight italic uppercase opacity-80">
                               "{review.text}"
                          </p>Ć –Ī—č–Ľ –Ņ—É–Ĺ–ļ—ā—É–į–Ľ–Ķ–Ĺ. –ü–ĺ–Ķ–∑–ī–ļ–į –≤ –ö–į–∑–Ī–Ķ–≥–ł –Ī—č–Ľ–į –Ĺ–Ķ–∑–į–Ī—č–≤–į–Ķ–ľ–ĺ–Ļ." },
                    { name: "Marco R.", location: "Rome, Italy", text: isEn ? "Best transfer service in Georgia. Fixed prices, no surprises. Highly recommended!" : "–õ—É—á—ą–ł–Ļ —ā—Ä–į–Ĺ—Ā—Ą–Ķ—Ä –≤ –ď—Ä—É–∑–ł–ł. –§–ł–ļ—Ā–ł—Ä–ĺ–≤–į–Ĺ–Ĺ—č–Ķ —Ü–Ķ–Ĺ—č, –Ī–Ķ–∑ —Ā—é—Ä–Ņ—Ä–ł–∑–ĺ–≤. –†–Ķ–ļ–ĺ–ľ–Ķ–Ĺ–ī—É—é!" },
                    { name: "Elena K.", location: "Berlin, DE", text: isEn ? "Clean car, friendly driver, fair price. This is exactly what we needed for our family trip." : "–ß–ł—Ā—ā–į—Ź –ľ–į—ą–ł–Ĺ–į, –≤–Ķ–∂–Ľ–ł–≤—č–Ļ –≤–ĺ–ī–ł—ā–Ķ–Ľ—Ć, —á–Ķ—Ā—ā–Ĺ–į—Ź —Ü–Ķ–Ĺ–į. –Ę–ĺ —á—ā–ĺ –Ĺ—É–∂–Ĺ–ĺ –ī–Ľ—Ź —Ā–Ķ–ľ—Ć–ł." }
                  ].map((review, i) => (
                      <div key={i} className="bg-white p-10 rounded-[40px] shadow-sm border border-slate-100 flex flex-col h-full group hover:shadow-xl transition-all duration-700">
                          <p className="text-lg text-slate-900 leading-relaxed mb-12 flex-grow font-black tracking-tight italic uppercase opacity-80">
                              "{review.text}"
                          </p>
                          <div className="flex items-center gap-4 pt-8 border-t border-slate-50">
                              <div className="w-12 h-12 rounded-2xl bg-slate-900 flex items-center justify-center text-amber-500 font-black text-lg">
                                  {review.name[0]}
                              </div>
                              <div className="flex flex-col">
                                  <span className="text-sm font-black text-slate-900 uppercase italic tracking-tighter">{review.name}</span>
                                  <span className="text-[10px] text-slate-400 font-bold uppercase tracking-widest">{review.location}</span>
                              </div>
                          </div>
                      </div>
                  ))}
              </div>
          </div>
      </div>

      {/* 6. INSTAGRAM CTA */}
      <div className="py-24 bg-slate-900 text-center relative overflow-hidden">
          <div className="max-w-4xl mx-auto px-4 relative z-10 flex flex-col items-center">
              <div className="w-20 h-20 rounded-[28px] bg-gradient-to-tr from-[#f09433] via-[#e6683c] to-[#bc1888] flex items-center justify-center shadow-2xl mb-10">
                  <SVGS.Instagram />
              </div>
              <h2 className="text-3xl md:text-5xl font-black text-white mb-8 tracking-tighter leading-none uppercase italic">
                  {isEn ? "Join Our Community" : "–ü—Ä–ł—Ā–ĺ–Ķ–ī–ł–Ĺ—Ź–Ļ—ā–Ķ—Ā—Ć"}
              </h2>
              <a 
                href="https://instagram.com/orbitrip.ge" 
                target="_blank" 
                rel="noopener noreferrer" 
                className="group flex items-center gap-4 bg-white text-slate-900 px-10 py-5 rounded-[24px] hover:scale-105 transition-all shadow-2xl font-black uppercase tracking-tight italic"
              >
                  @orbitrip.ge <ArrowRight size={20} className="group-hover:translate-x-2 transition-transform" />
              </a>
          </div>
      </div>
    </div>
  );
};

export default HomeLanding;